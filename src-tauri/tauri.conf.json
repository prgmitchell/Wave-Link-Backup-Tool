{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wave Link Backup Tool",
  "version": "0.2.0",
  "identifier": "com.prgmitchell.wavelinkbackuptool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Wave Link Backup Tool",
        "width": 1050,
        "height": 780,
        "minWidth": 900,
        "minHeight": 680,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "prgmitchell",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
